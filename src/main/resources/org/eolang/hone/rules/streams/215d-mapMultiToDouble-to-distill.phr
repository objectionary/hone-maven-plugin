---
# yamllint disable rule:line-length
# Primitive sibling of 215; see 215b for the rationale.
# Stream.mapMultiToDouble(BiConsumer) → cps Φ.hone.distill with
# `bridge-output ↦ "D"`. Issue #570 Step 9.
name: mapMultiToDouble-to-distill
pattern: |
  ⟦
    φ ↦ Φ.hone.lambda,
    class ↦ 𝑒-class,
    method ↦ "accept",
    interface ↦ "()Ljava/util/function/BiConsumer;",
    lambda-signature ↦ "(Ljava/lang/Object;Ljava/lang/Object;)V",
    bridge-signature ↦ 𝑒-bridge-signature,
    static ↦ "true",
    opcode ↦ 𝑒-opcode,
    target ↦ ⟦
      handle ↦ 𝑒-target-handle,
      class ↦ 𝑒-class,
      method ↦ 𝑒-target-method,
      signature ↦ 𝑒-target-signature,
      is-interface ↦ 𝑒-target-is-interface
    ⟧,
    stream ↦ ⟦
      class ↦ "java/util/stream/Stream",
      method ↦ "mapMultiToDouble",
      signature ↦ "(Ljava/util/function/BiConsumer;)Ljava/util/stream/DoubleStream;"
    ⟧
  ⟧
result: |
  ⟦
    φ ↦ Φ.hone.distill,
    class ↦ 𝑒-class,
    bridge-input ↦ "Ljava/lang/Object;",
    bridge-output ↦ "D",
    start ↦ "mapMultiToDouble",
    accepted ↦ 𝑒-accepted,
    returned ↦ "D",
    static ↦ "true",
    captures ↦ ⟦ ρ ↦ ∅ ⟧,
    emit-shape ↦ "cps",
    body ↦ ⟦
      t0-aload-consumer ↦ ⟦
        φ ↦ Φ.jeo.opcode.aload,
        i1 ↦ 1
      ⟧,
      t1-invoke ↦ ⟦
        φ ↦ Φ.jeo.opcode.𝜏-target-opcode,
        i2 ↦ 𝑒-class,
        i3 ↦ 𝑒-target-method,
        i4 ↦ 𝑒-target-signature,
        i5 ↦ 𝑒-target-is-interface
      ⟧
    ⟧
  ⟧
where:
  - meta: 𝑒-accepted
    function: sed
    args:
      - 𝑒-bridge-signature
      - '"s/\\((.+)Ljava\\/util\\/function\\/DoubleConsumer;\\)V/$1/g"'
  - meta: 𝜏-target-opcode
    function: tau
    args: [𝑒-opcode]
